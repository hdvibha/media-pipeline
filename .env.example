# Copy this file to .env and adjust as needed.

NODE_ENV=development
PORT=3000

# Postgres connection string. When running via docker-compose, host "postgres"
# resolves to the db container; when running locally against docker-compose's
# exposed port, use "localhost".
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/media_pipeline

REDIS_HOST=localhost
REDIS_PORT=6379

STORAGE_DIR=storage/uploads
MAX_UPLOAD_SIZE_BYTES=15728640

# Analysis thresholds (all optional, sensible defaults are baked in)
BLUR_VARIANCE_THRESHOLD=100
BRIGHTNESS_LOW_THRESHOLD=60
BRIGHTNESS_HIGH_THRESHOLD=235
DUPLICATE_HAMMING_THRESHOLD=6
MIN_WIDTH=480
MIN_HEIGHT=360

QUEUE_CONCURRENCY=2
MAX_JOB_ATTEMPTS=3

LOG_LEVEL=info
